# ===============================
# Product Optimization Module ENV
# ===============================
# Скопируйте этот файл в .env и заполните реальные значения.
# Экспорт на Ozon оставляем без изменений (ручная настройка) —
# в этом модуле обрабатываем только Яндекс.Маркет, Wildberries, eBay.

# === Insales API (источник каталога) ===
INSALES_SHOP=bireta.ru
INSALES_API_KEY=
INSALES_PASSWORD=
INSALES_TIMEOUT=30
INSALES_PER_PAGE=100

# === Shopware 6 API (источник для eBay) ===
SHOPWARE_URL=https://biretos.ae
SHOPWARE_CLIENT_ID=
SHOPWARE_CLIENT_SECRET=
SHOPWARE_TIMEOUT=30

# === PostgreSQL (история экспортов, маппинги) ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=biretos_automation
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=prefer

# === OpenRouter (AI-провайдер) ===
OPENROUTER_API_KEY=
OPENROUTER_REFERER=https://biretos.ae
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions

# Модели (можно переопределить при необходимости)
OPENROUTER_MODEL_ANALYZER=openai/gpt-5-mini          # анализ качества карточки
OPENROUTER_MODEL_GENERATOR=openai/gpt-5-codex        # генерация названий, SEO, атрибутов
OPENROUTER_MODEL_DESCRIPTION=anthropic/claude-4.5-sonnet
OPENROUTER_MODEL_VISION=google/gemini-2.5-pro        # анализ изображений

# === Telegram (уведомления, опционально) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Настройки оптимизации ===
MAX_PRODUCTS_PER_RUN=200
OPTIMIZATION_MODE=full              # full | quick | images_only
TARGET_MARKETPLACES=yandex,wildberries,ebay
EXCLUDE_MARKETPLACES=ozon           # защита от случайной оптимизации Ozon
PRIORITY_MODE=failed_only           # failed_only | needs_review | all
GENERATE_PATCHES=true
GENERATE_SQL_PATCHES=true
GENERATE_JSON_PATCHES=true
REPORT_FORMAT=markdown              # markdown | pdf
OUTPUT_DIR=reports
PATCHES_DIR=patches
LOG_LEVEL=INFO

# === Промежуточные каталоги (создаются автоматически) ===
TEMP_DIR=.tmp


