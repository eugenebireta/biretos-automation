# ChatGPT USA Route Configuration
# Скопируйте этот файл в .env и заполните реальные значения

# USA VPS Configuration
XRAY_VPS_IP=216.9.227.124
XRAY_VPS_PORT=10800

# VLESS UUID (сгенерируйте новый UUID для безопасности)
XRAY_VLESS_UUID=e01f3fb1-f4b8-47c8-a032-2daaa679c816

# X-Ray Executable Path (Windows)
XRAY_EXE_PATH=C:\Users\Eugene\xray\xray.exe

# X-Ray Config Output Path (где будет сохранен сгенерированный конфиг)
XRAY_CONFIG_PATH=C:\Users\Eugene\xray\config.json

# Proxy Configuration
PROXY_SOCKS5_HOST=127.0.0.1
PROXY_SOCKS5_PORT=10808

# Optional: WebSocket Echo Test URL (оставьте пустым для пропуска)
WS_ECHO_URL=

# Optional: Enable Playwright HAR collection (true/false)
PLAYWRIGHT_ENABLED=false

# Optional: Test targets (можно добавить дополнительные домены)
TEST_DOMAINS=chatgpt.com,openai.com
