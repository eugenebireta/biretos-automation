# Biretos Automation — Docker Compose Environment Variables
# Copy this file to .env and fill in your values
# Usage: cp docker-compose.env.template .env

#═══════════════════════════════════════════════════════════════════════════════
# PostgreSQL Configuration
#═══════════════════════════════════════════════════════════════════════════════
POSTGRES_DB=biretos_automation
POSTGRES_USER=biretos_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432

#═══════════════════════════════════════════════════════════════════════════════
# n8n Configuration
#═══════════════════════════════════════════════════════════════════════════════
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me

# Webhook URL (change to your domain in production)
WEBHOOK_URL=http://localhost:5678
N8N_EDITOR_BASE_URL=http://localhost:5678

#═══════════════════════════════════════════════════════════════════════════════
# Insales API
#═══════════════════════════════════════════════════════════════════════════════
INSALES_SHOP=your-shop.insales.ru
INSALES_API_KEY=your_insales_api_key
INSALES_API_PASSWORD=your_insales_api_password

#═══════════════════════════════════════════════════════════════════════════════
# OpenRouter (AI Services)
#═══════════════════════════════════════════════════════════════════════════════
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_REFERER=https://biretos.ae
OPENROUTER_MODEL_CATEGORY=openai/gpt-5-mini
OPENROUTER_MODEL_VALIDATOR=openai/gpt-5-codex
OPENROUTER_MODEL_FALLBACK=anthropic/claude-4.5-sonnet

#═══════════════════════════════════════════════════════════════════════════════
# Telegram Bot
#═══════════════════════════════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

#═══════════════════════════════════════════════════════════════════════════════
# Image Processor
#═══════════════════════════════════════════════════════════════════════════════
IMAGE_PROCESSOR_URL=http://image-processor:8000
IMAGE_PROCESSOR_PORT=8000
IMAGE_PROCESSOR_LOG_LEVEL=info
IMAGE_PROCESSOR_WORKERS=4

#═══════════════════════════════════════════════════════════════════════════════
# Redis
#═══════════════════════════════════════════════════════════════════════════════
REDIS_PORT=6379

#═══════════════════════════════════════════════════════════════════════════════
# Shopware (Optional)
#═══════════════════════════════════════════════════════════════════════════════
SHOPWARE_URL=https://your-shop.shopware.com
SHOPWARE_CLIENT_ID=your_shopware_client_id
SHOPWARE_CLIENT_SECRET=your_shopware_client_secret

#═══════════════════════════════════════════════════════════════════════════════
# Gemini API (Optional - for image analysis)
#═══════════════════════════════════════════════════════════════════════════════
GEMINI_API_KEY=your_gemini_api_key

#═══════════════════════════════════════════════════════════════════════════════
# System Configuration
#═══════════════════════════════════════════════════════════════════════════════
TIMEZONE=Asia/Almaty
TZ=Asia/Almaty

#═══════════════════════════════════════════════════════════════════════════════
# Testing & Development
#═══════════════════════════════════════════════════════════════════════════════
TEST_MODE=false
DRY_RUN=false
DEBUG=false






