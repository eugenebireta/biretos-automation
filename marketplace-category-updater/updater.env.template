# Update settings
UPDATE_INTERVAL_DAYS=90
CONFIDENCE_THRESHOLD=0.9
AUTO_UPDATE_HIGH_CONFIDENCE=true
DRY_RUN=false

# Logging
CATEGORY_UPDATER_LOG_LEVEL=info
