# Marketplace Category Auto-Updater environment variables

# Base path for local scripts (optional override)
CATEGORY_UPDATER_BASE_PATH=/opt/projects/biretos-automation/marketplace-category-updater

# Marketplace API credentials
OZON_CLIENT_ID=
OZON_API_KEY=
OZON_LANGUAGE=DEFAULT

YANDEX_TOKEN=
YANDEX_CAMPAIGN_ID=

WB_CATEGORY_URL=https://static-basket-01.wb.ru/vol0/data/subject-base.json

EBAY_ACCESS_TOKEN=
EBAY_CATEGORY_TREE_ID=0

# OpenRouter for AI
OPENROUTER_API_KEY=
OPENROUTER_REFERER=https://biretos.ae

# PostgreSQL connection
POSTGRES_HOST=localhost
POSTGRES_DB=biretos_automation
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_CREDENTIAL_ID=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_CREDENTIAL_ID=

# n8n API (if manual triggering needed)
N8N_URL=https://n8n.yourdomain.com
