# =========================
# Manual Launch Configuration
# =========================
# Скопируйте этот файл в manual-launch/config.env и заполните значения.
# Все параметры используются BAT/PS1 скриптами для обращения к n8n, БД и доп. сервисам.

# --- n8n ------------------------------------------------------
# Базовый хост n8n с протоколом (https://host или http://127.0.0.1:5678)
N8N_HOST=http://216.9.227.124:5678
# Укажите IP сервера, если локальный ПК не может разрешить домен (опционально).
N8N_RESOLVE_IP=

# API-ключ n8n (используется некоторыми workflow для аутентификации).
N8N_API_KEY=

# --- Webhook endpoints ---------------------------------------
# Пути (path) до соответствующих webhook'ов. Можно менять при переносе на другой сервер.
EXPORT_DRY_RUN_WEBHOOK=/webhook/marketplace-export-dry-run
EXPORT_LIMITED_WEBHOOK=/webhook/marketplace-export-limited
EXPORT_FULL_WEBHOOK=/webhook/marketplace-export-full
HEALTH_CHECK_WEBHOOK=/webhook/marketplace-health-check
AUTOHEAL_TRIGGER_WEBHOOK=/webhook/autoheal-trigger
AUTOHEAL_APPLY_WEBHOOK=/webhook/autoheal-apply
STOP_AND_CLEAN_WEBHOOK=/webhook/marketplace-stop-and-clean

# --- Credentials для вспомогательных операций ----------------
# Используются внутри workflow (передаются в payload и логах при необходимости).
INSALES_SHOP=biretos.insales.ru
INSALES_API_KEY=
INSALES_API_PASSWORD=

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=biretos_automation
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Внешние сервисы для health-check и автоисправлений.
OPENROUTER_API_KEY=
OPENROUTER_REFERER=https://biretos.ae
IMAGE_PROCESSOR_URL=https://images.biretos.ae

# Дополнительные ключи (оставьте пустыми, если не используются).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Применение патчей ---------------------------------------
# Если Auto-Heal применяет патчи через вспомогательный сервис генерации,
# можно указать его URL. Если используются webhooks n8n — оставьте пустым.
AUTOHEAL_GENERATOR_URL=

# --- Общие параметры -----------------------------------------
# Дополнительные настройки скриптов (не обязательно).
# Например, таймауты или имена логов. Добавляйте по мере необходимости:
# REQUEST_TIMEOUT_SECONDS=90

