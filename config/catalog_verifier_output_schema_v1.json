{
  "schema_version": "catalog_verifier_output_schema_v1",
  "type": "object",
  "required": [
    "verifier_model",
    "verifier_version",
    "verdict",
    "confidence",
    "rationale_short",
    "blocking_reason_codes",
    "suggested_action",
    "suggested_review_bucket",
    "evidence_sufficiency",
    "contradictions_found",
    "safe_to_autopublish"
  ],
  "properties": {
    "verifier_model": {
      "type": "string",
      "minLength": 1
    },
    "verifier_version": {
      "type": "string",
      "minLength": 1
    },
    "verdict": {
      "type": "string",
      "enum": [
        "CONFIRM_REVIEW",
        "CONFIRM_DRAFT",
        "CONFIRM_AUTOPUBLISH_ELIGIBLE",
        "ESCALATE_OWNER",
        "INSUFFICIENT_EVIDENCE"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "rationale_short": {
      "type": "string",
      "maxLength": 400
    },
    "blocking_reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "suggested_action": {
      "type": "string",
      "enum": [
        "KEEP_DETERMINISTIC_DECISION",
        "ROUTE_TO_REVIEW",
        "ESCALATE_OWNER",
        "REQUEST_MORE_EVIDENCE"
      ]
    },
    "suggested_review_bucket": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_sufficiency": {
      "type": "string",
      "enum": [
        "SUFFICIENT",
        "PARTIAL",
        "INSUFFICIENT"
      ]
    },
    "contradictions_found": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "safe_to_autopublish": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
