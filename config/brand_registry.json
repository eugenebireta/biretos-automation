  "_universal_rules": {
    "ean_validation": {
      "format": "13 digits",
      "checksum": "GS1 EAN-13 mod-10 algorithm",
      "python_check": "def validate_ean13(ean): digits=[int(d) for d in ean]; s=sum(digits[i]*(3 if i%2 else 1) for i in range(12)); return (10-(s%10))%10 == digits[12]"
    },
    "datasheet_search_queries": [
      "{brand} {pn} datasheet filetype:pdf",
      "{pn} datenblatt filetype:pdf",
      "{brand} {pn} data sheet site:{manufacturer_domain}",
      "{pn} specifications PDF"
    ],
    "quality_red_flags": [
      "Title mentions different product type than seed_name",
      "EAN prefix doesn't match brand's known company prefix",
      "Description is generic 'high-quality product' boilerplate",
      "Weight/dimensions missing but product clearly physical",
      "Datasheet size >10MB with zero extracted specs (wrong document)",
      "PN format doesn't match any known brand pattern"
    ],
    "honeywell_sub_brand_detection": {
      "PEHA": "8-digit numeric with 4-digit middle",
      "Esser": "6-digit with .NN color suffix",
      "Howard Leight": "10xxxxx 7-digit",
      "Sperian": "10xxxxx-RU with RU suffix",
      "Notifier": "EVCS-* prefix",
      "Morley": "legacy products, Notifier UK branch"
    }
  }
