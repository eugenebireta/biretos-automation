  "PEHA": {
    "brand_name": "PEHA",
    "parent_company": "Honeywell",
    "country": "Germany",
    "product_families": ["switches", "sockets", "frames", "dimmers", "buttons"],
    "pn_patterns": [
      {"regex": "^[0-9]{6}$", "description": "6-digit numeric", "example": "109411"},
      {"regex": "^[0-9]{8}$", "description": "8-digit with leading zeros", "example": "00020211"}
    ],
    "ean_rule": {
      "company_prefix": "4010105",
      "formula": "4010105 + first_5_of_normalized_pn + check_digit",
      "confidence": "high",
      "verified_rate": 0.875,
      "python_snippet": "def predict_peha_ean(pn): pn5 = pn.lstrip('0').zfill(6)[:5]; return '4010105' + pn5 + calc_ean13_check('4010105' + pn5)"
    },
    "datasheet_location_pattern": [
      "https://prod-edam.honeywell.com/content/dam/honeywell-edam/hbt/en-us/documents/literature-and-specs/datasheets/peha-en/hbt-ep-{pn}-en-datasheet.pdf",
      "https://prod-edam.honeywell.com/content/dam/honeywell-edam/hbt/en-us/documents/literature-and-specs/datasheets/peha-de/hbt-ep-{pn}-de-datasheet.pdf"
    ],
    "datasheet_access_notes": "prod-edam.honeywell.com blocks Russian IPs. Use USA VPS (216.9.227.124) to download.",
    "datasheet_ean_location": "Usually on page 2 in 'Material No.' / 'Article No.' / 'EAN-code' table",
    "trusted_sources": {
      "specs_and_datasheet": ["peha.de", "prod-edam.honeywell.com", "pehastore.de"],
      "price": ["pehastore.de", "elektroversand-schmidt.de", "voltking.de", "conrad.de", "conrad.ch", "watt24.com"],
      "photo_manufacturer": ["pehastore.de", "peha.de", "asset.conrad.com"],
      "eu_distributors": ["elektronetshop.de", "elecena.pl"]
    },
    "common_pitfalls": [
      "Honeywell Excel contains many non-PEHA items mislabeled as PEHA — verify title matches electrical installation products",
      "Pack prices on Conrad — if price >200 EUR, check for '10 St' or '5er Pack' in title",
      "Some PEHA sub-series (AURA, NOVA, Dialog) have different datasheets"
    ],
    "series_prefixes": {
      "0002xxxx": "NOVA",
      "1xxxxx (excluding 10xxxx)": "AURA",
      "2xxxxx": "Dialog"
    }
  },

