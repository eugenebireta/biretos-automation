    "schema_version": {
      "type": "string",
      "const": "shadow_logging_record_schema_v0"
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "task",
        "executor_run",
        "evidence_pack",
        "continuity_artifact",
        "judge_verdict",
        "human_verdict",
        "final_outcome",
        "status_event",
        "correction"
      ]
    },
    "record_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "trajectory_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "parent_id": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 200
    },
    "timestamp": {
      "type": "string",
      "minLength": 1,
      "maxLength": 40
    },
    "role": {
      "type": "string",
      "enum": [
        "executor",
        "judge",
        "reviewer",
        "auditor",
        "recon",
        "human_owner",
        "system"
      ]
    },
    "task_type": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "risk": {
      "type": "string",
      "enum": [
        "LOW",
        "SEMI",
        "CORE",
        "UNKNOWN"
      ]
    },
    "provider": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "model": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "input_ref": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 500
    },
    "output_ref": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 500
    },
    "evidence_ref": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 500
    },
    "verdict_ref": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 500
    },
    "final_outcome_label": {
      "type": "string",
      "enum": [
        "accepted_outcome",
        "rejected_outcome",
        "superseded_outcome",
        "needs_human_review"
      ]
    },
    "trajectory_quality_label": {
      "type": "string",
      "enum": [
        "good_trajectory",
        "bad_trajectory",
        "blocked_trajectory",
        "inconclusive_trajectory"
      ]
    },
    "redaction_status": {
      "type": "string",
      "enum": [
        "not_required",
        "redacted_inline",
        "ref_only",
        "contains_secret_blocked",
        "contains_sensitive_blocked"
      ]
    },
    "linkage_ids": {
      "type": "object",
      "required": [
        "task_id",
        "request_id",
        "run_id",
        "attempt_id",
        "evidence_pack_id",
        "continuity_id",
        "judge_verdict_id",
        "human_verdict_id",
        "outcome_id",
        "correction_id"
