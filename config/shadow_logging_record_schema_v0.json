        "task_id": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 200
        },
        "request_id": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 200
        },
        "run_id": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 200
        },
        "attempt_id": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 200
        },
        "evidence_pack_id": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 200
        },
        "continuity_id": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 200
        },
        "judge_verdict_id": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 200
        },
        "human_verdict_id": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 200
        },
        "outcome_id": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 200
        },
        "correction_id": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 200
        }
      },
      "additionalProperties": false
