{
  "schema_version": "shadow_logging_record_schema_v0",
  "type": "object",
  "required": [
    "schema_version",
    "record_kind",
    "record_id",
    "trajectory_id",
    "parent_id",
    "timestamp",
    "role",
    "task_type",
    "risk",
    "provider",
    "model",
    "input_ref",
    "output_ref",
    "evidence_ref",
    "verdict_ref",
