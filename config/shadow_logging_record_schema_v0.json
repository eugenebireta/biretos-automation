    "run_status": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "STARTED",
        "RUNNING",
        "COMPLETED",
        "FAILED_EXIT",
        "FAILED_TIMEOUT",
        "FAILED_IDLE",
        "RETRYING",
        "ABORTED_MAX_RETRIES",
        "STALLED",
        "UNKNOWN",
        null
      ]
    },
    "attempt_index": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "retry_count": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "correction_type": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "human_correction",
        "owner_override",
        "rework",
        "retry",
        "supersede",
        null
      ]
    },
    "authoritative_label_source": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "human_owner",
        "authoritative_system_record",
        "none",
        null
      ]
    },
    "auxiliary_trace": {
      "type": "boolean"
    },
    "notes": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 1000
    }
