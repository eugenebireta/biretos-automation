{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_version": "review_reason_schema_v1",
  "title": "Phase A Review Reason",
  "type": "object",
  "required": [
    "reason_code",
    "field",
    "severity",
    "candidate_ids",
    "evidence_ids",
    "policy_rule_id",
    "bucket"
  ],
  "properties": {
    "reason_code": {
      "type": "string"
    },
    "field": {
      "type": "string",
      "enum": [
        "title",
        "image",
        "price",
        "pdf",
        "identity"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "INFO",
        "WARNING",
        "ERROR"
      ]
    },
    "candidate_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "policy_rule_id": {
      "type": "string"
    },
    "bucket": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
