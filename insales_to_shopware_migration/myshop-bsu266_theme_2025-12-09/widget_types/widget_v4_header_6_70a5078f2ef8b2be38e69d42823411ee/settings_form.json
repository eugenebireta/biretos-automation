{
  "{{ messages.header }}": [
    {
      "group_name":"{{ messages.collections_menu }}",
      "items": [
        {
          "class": "range",
          "name": "menu-grid-list-min-width",
          "label": "{{ messages.menu_item_min_width }}",
          "min": 150,
          "max" : 500,
          "step": 10,
          "type":"number",
          "with_btns": true,
          "unit": "px"
        },
        {
          "class": "range",
          "name": "menu-grid-list-row-gap",
          "min": 0,
          "max": 10,
          "step": 0.5,
          "label": "{{ messages.menu_row_gap }}",
          "type":"number",
          "with_btns": true,
          "unit": "rem"
        },
        {
          "class": "range",
          "name": "menu-grid-list-column-gap",
          "min": 0,
          "max": 10,
          "step": 0.5,
          "label": "{{ messages.menu_column_gap }}",
          "type":"number",
          "with_btns": true,
          "unit": "rem"
        },
        {
          "class": "range",
          "name": "subcollections-items-limit",
          "min": 1,
          "max": 100,
          "step": 1,
          "label": "{{ messages.subcollections_items_limit }}",
          "type":"number",
          "with_btns": true
        },
        {
          "class": "range",
          "name": "menu-img-ratio",
          "label": "{{ messages.image_ratio }}",
          "min": 0.5,
          "max" : 2,
          "step": 0.1,
          "type":"number",
          "with_btns": true
        },
        {
          "class": "checkbox",
          "name": "hide-menu-photo",
          "label": "{{ messages.hide_menu_photo }}",
          "value": null,
          "type": "checkbox",
          "general": true,
          "general_position": 100
        }
      ]
    },
    {
      "group_name":"{{ messages.logo_img }}",
      "items": [
        {
          "name":"logo-img",
          "label":"{{ messages.logo_img }}",
          "value":null,
          "type":"file",
          "general": true,
          "general_position": 1,
          "with-generate-logo": true
        },
        {
          "class":"range",
          "name":"logo-max-width",
          "min":100,
          "max":280,
          "step":20,
          "label":"{{ messages.logo_max_width }}",
          "type":"number",
          "with_btns": true,
          "unit":"px",
          "general": true,
          "general_position": 1
        }
      ]
    },
    {
      "group_name":"{{ messages.info_menu }}",
      "items": [
        {
          "class": "text",
          "name": "menu_handle",
          "label": "{{ messages.menu_handle }}",
          "value": "main-menu",
          "type": "navigation",
          "placeholder": null,
          "general": true,
          "general_position": 1
        }
      ]
    },
    {
      "group_name":"{{ messages.phone }}",
      "items": [
        {
          "class": "text",
          "name": "phone_number",
          "label": "{{ messages.phone }}",
          "value": "",
          "type": "text",
          "placeholder": null,
          "general": true,
          "general_position": 1
        },
        {
          "class": "text",
          "name": "phone_number_2",
          "label": "{{ messages.phone }} 2",
          "value": "",
          "type": "text",
          "placeholder": null
        }
      ]
    },
    {
      "group_name":"{{ messages.elements }}",
      "items": [
        {
          "class": "checkbox",
          "name": "hide-language",
          "label": "{{ messages.hide_language }}",
          "value": null,
          "type": "checkbox",
          "help": "{{ messages.hide_language_help }}",
          "general": true,
          "general_position": 100
        },
        {
          "class": "checkbox",
          "name": "hide-compare",
          "label": "{{ messages.hide_comparison }}",
          "value": null,
          "type": "checkbox",
          "general": true,
          "general_position": 100,
          "help": "{{ messages.hide_compare_help }}",
          "enable_server_reload": true
        },
        {
          "class": "checkbox",
          "name": "hide-personal",
          "label": "{{ messages.hide_personal }}",
          "value": null,
          "type": "checkbox",
          "general": true,
          "general_position": 100
        },
        {
          "class": "checkbox",
          "name": "hide-favorite",
          "label": "{{ messages.hide_favorites }}",
          "value": null,
          "type": "checkbox",
          "general": true,
          "general_position": 100,
          "enable_server_reload": true,
          "help": "{{ messages.hide_favorite_help }}"
        }
      ]
    }
  ],
  "{{ messages.label_widget }}": [
    {
      "group_name":"{{ messages.background }}",
      "items": [
        {
          "name":"bg",
          "label":"{{ messages.widget_background_color }}",
          "value":"",
          "type":"color",
          "clearable": true
        },
        {
          "class": "checkbox",
          "name": "header-wide-bg",
          "label": "{{ messages.wide_background }}",
          "value": null,
          "type": "checkbox"
        }
      ]
    },
    {
      "group_name":"{{ messages.indentation }}",
      "items": [
        {
          "class": "range",
          "name": "header-top-pt",
          "min": 0,
          "max": 10,
          "step": 0.5,
          "label": "{{ messages.header_top_padding_top }}",
          "type":"number",
          "with_btns": true,
          "unit": "vw"
        },
        {
          "class": "range",
          "name": "header-top-pb",
          "min": 0,
          "max": 10,
          "step": 0.5,
          "label": "{{ messages.header_top_padding_bottom }}",
          "type":"number",
          "with_btns": true,
          "unit": "vw"
        },
        {
          "class": "range",
          "name": "header-main-pt",
          "min": 0,
          "max": 10,
          "step": 0.5,
          "label": "{{ messages.header_main_padding_top }}",
          "type":"number",
          "with_btns": true,
          "unit": "vw"
        },
        {
          "class": "range",
          "name": "header-main-pb",
          "min": 0,
          "max": 10,
          "step": 0.5,
          "label": "{{ messages.header_main_padding_bottom }}",
          "type":"number",
          "with_btns": true,
          "unit": "vw"
        }
      ]
    },
    {
      "group_name":"{{ messages.content }}",
      "items": [
        {
          "class": "number",
          "name": "layout-content-max-width",
          "min": 1060,
          "max": 2000,
          "label": "{{ messages.content_max_width }}",
          "type": "number",
          "unit": "px",
          "hide_mobile": true
        },
        {
          "class": "checkbox",
          "name": "header-wide-content",
          "label": "{{ messages.wide_content }}",
          "value": null,
          "type": "checkbox",
          "hide_mobile": true
        }
      ]
    },
    {
      "group_name":"{{ messages.adaptive }}",
      "items": [
        {
          "class": "checkbox",
          "name": "hide-desktop",
          "label": "{{ messages.hide_desktop }}",
          "value": null,
          "type": "checkbox"
        },
        {
          "class": "checkbox",
          "name": "hide-mobile",
          "label": "{{ messages.hide_mobile }}",
          "value": null,
          "type": "checkbox"
        }
      ]
    }
  ]
}
