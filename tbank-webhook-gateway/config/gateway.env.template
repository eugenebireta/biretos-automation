# T-Bank Webhook Gateway Environment Variables
# Скопируйте в gateway.env и заполните значения

# n8n Webhook URL (полный путь до webhook endpoint)
N8N_WEBHOOK_URL=https://n8n.biretos.ae/webhook/tbank-invoice-paid

# n8n Webhook Secret (для HMAC подписи)
N8N_WEBHOOK_SECRET=your_n8n_webhook_secret_here

# Timeout для запросов к n8n (секунды)
N8N_TIMEOUT=10

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/tbank-gateway/webhook.log








