    "descriptions_all": {
      "claude": "–Т–Є–љ—В DKC CM010610 —Б –Ї—А–µ—Б—В–Њ–Њ–±—А–∞–Ј–љ—Л–Љ —И–ї–Є—Ж–µ–Љ —В–Є–њ–Њ—А–∞–Ј–Љ–µ—А–∞ –Ь6—Е10 —П–≤–ї—П–µ—В—Б—П –Ї—А–µ–њ—С–ґ–љ—Л–Љ —Н–ї–µ–Љ–µ–љ—В–Њ–Љ –Є–Ј —Б–Є—Б—В–µ–Љ—Л –Љ–Њ–љ—В–∞–ґ–љ—Л—Е –Љ–µ—В–Є–Ј–Њ–≤ ¬ЂM5 Combitech¬ї –њ—А–Њ–Є–Ј–≤–Њ–і—Б—В–≤–∞ DKC. –Т–Є–љ—В –њ—А–µ–і–љ–∞–Ј–љ–∞—З–µ–љ –і–ї—П —Б–Њ–µ–і–Є–љ–µ–љ–Є—П –Љ–µ—В–∞–ї–ї–Є—З–µ—Б–Ї–Є—Е –Ї–∞–±–µ–ї—М–љ—Л—Е –ї–Њ—В–Ї–Њ–≤ –Љ–µ–ґ–і—Г —Б–Њ–±–Њ–є, –∞ —В–∞–Ї–ґ–µ –і–ї—П –Ї—А–µ–њ–ї–µ–љ–Є—П –Ї –љ–Є–Љ —А–∞–Ј–ї–Є—З–љ—Л—Е –Љ–Њ–љ—В–∞–ґ–љ—Л—Е –∞–Ї—Б–µ—Б—Б—Г–∞—А–Њ–≤ вАФ –Ї–Њ–љ—Б–Њ–ї–µ–є, –њ–Њ–і–≤–µ—Б–Њ–≤, —В—А–∞–≤–µ—А—Б –љ–∞ –Њ—Б–љ–Њ–≤–µ –°-–Њ–±—А–∞–Ј–љ–Њ–≥–Њ –њ—А–Њ—Д–Є–ї—П —В–Є–њ–Њ—А–∞–Ј–Љ–µ—А–Њ–≤ 21x41 –Є 41x41. –Ш–Ј–≥–Њ—В–Њ–≤–ї–µ–љ –Є–Ј –Ј–∞–Ї–∞–ї—С–љ–љ–Њ–є —Б—В–∞–ї–Є —Б –≥–∞–ї—М–≤–∞–љ–Є—З–µ—Б–Ї–Є–Љ/—Н–ї–µ–Ї—В—А–Њ–ї–Є—В–Є—З–µ—Б–Ї–Є–Љ —Ж–Є–љ–Ї–Њ–≤—Л–Љ –њ–Њ–Ї—А—Л—В–Є–µ–Љ, —З—В–Њ –Њ–±–µ—Б–њ–µ—З–Є–≤–∞–µ—В –≤—Л—Б–Њ–Ї—Г—О –њ—А–Њ—З–љ–Њ—Б—В—М –Є –љ–∞–і—С–ґ–љ—Г—О –Ј–∞—Й–Є—В—Г –Њ—В –Ї–Њ—А—А–Њ–Ј–Є–Є. –У–Њ–ї–Њ–≤–Ї–∞ –≤–Є–љ—В–∞ –Є–Љ–µ–µ—В –њ–Њ–ї—Г–њ–Њ—В–∞–є–љ—Г—О (—Б—Д–µ—А–Є—З–µ—Б–Ї—Г—О) —Д–Њ—А–Љ—Г —Б –Ї—А–µ—Б—В–Њ–Њ–±—А–∞–Ј–љ—Л–Љ —И–ї–Є—Ж–µ–Љ Phillips, —З—В–Њ –њ–Њ–Ј–≤–Њ–ї—П–µ—В —Б–Ї—А—Л–≤–∞—В—М –≤–Є–љ—В –њ–Њ—Б–ї–µ —Г—Б—В–∞–љ–Њ–≤–Ї–Є –Є —Б–Њ–Ј–і–∞–≤–∞—В—М –∞–Ї–Ї—Г—А–∞—В–љ—Л–є –≤–љ–µ—И–љ–Є–є –≤–Є–і –Ї–Њ–љ—Б—В—А—Г–Ї—Ж–Є–Є. –Т–Є–љ—В —Г—Б—В–∞–љ–∞–≤–ї–Є–≤–∞–µ—В—Б—П –≤ –љ–µ–Ј–µ–љ–Ї–Њ–≤–∞–љ–љ–Њ–µ –Њ—В–≤–µ—А—Б—В–Є–µ —Б –њ—А–µ–і–≤–∞—А–Є—В–µ–ї—М–љ–Њ –њ–Њ–і–≥–Њ—В–Њ–≤–ї–µ–љ–љ–Њ–є –Љ–µ—В—А–Є—З–µ—Б–Ї–Њ–є —А–µ–Ј—М–±–Њ–є. –Я–Њ—Б—В–∞–≤–ї—П–µ—В—Б—П –≤ —Г–њ–∞–Ї–Њ–≤–Ї–∞—Е –њ–Њ 200 —И—В—Г–Ї. –Ф–∞–љ–љ—Л–є –Ї—А–µ–њ—С–ґ –Љ–Њ–ґ–µ—В –њ—А–Є–Љ–µ–љ—П—В—М—Б—П –і–ї—П —Б–±–Њ—А–Ї–Є –≤—Б–µ—Е –≤–Є–і–Њ–≤ –Љ–µ—В–∞–ї–ї–Є—З–µ—Б–Ї–Є—Е –Ї–∞–±–µ–ї–µ–љ–µ—Б—Г—Й–Є—Е —Б–Є—Б—В–µ–Љ –Ф–Ъ–°, –≤–Ї–ї—О—З–∞—П –ї–Є—Б—В–Њ–≤—Л–µ –Є –њ—А–Њ–≤–Њ–ї–Њ—З–љ—Л–µ –ї–Њ—В–Ї–Є, –ї–µ—Б—В–љ–Є—З–љ—Л–µ –ї–Њ—В–Ї–Є –Є –њ–µ—А—Д–Њ—А–Є—А–Њ–≤–∞–љ–љ—Л–µ –Ї–Њ—А–Њ–±–∞.",
      "gpt": "DKC CM010610 вАФ —Н—В–Њ –Ї—А–µ–њ–µ–ґ–љ—Л–є –±–Њ–ї—В M6x10, –Ї–Њ—В–Њ—А—Л–є –Є—Б–њ–Њ–ї—М–Ј—Г–µ—В—Б—П –≤ –Ї–∞–±–µ–ї–µ–љ–µ—Б—Г—Й–Є—Е –Є –Љ–Њ–љ—В–∞–ґ–љ—Л—Е —Б–Є—Б—В–µ–Љ–∞—Е DKC. –Т –Њ—Д–Є—Ж–Є–∞–ї—М–љ–Њ–Љ –Ї–∞—В–∞–ї–Њ–≥–µ –Њ–љ –Њ–њ–Є—Б–∞–љ –Ї–∞–Ї square neck bolt M6x10, —В–Њ –µ—Б—В—М –±–Њ–ї—В —Б –Ї–≤–∞–і—А–∞—В–љ—Л–Љ –њ–Њ–і–≥–Њ–ї–Њ–≤–Ї–Њ–Љ, —А–∞—Б—Б—З–Є—В–∞–љ–љ—Л–є –љ–∞ —Б–Њ–≤–Љ–µ—Б—В–љ—Г—О —А–∞–±–Њ—В—Г —Б —Д–Є—А–Љ–µ–љ–љ—Л–Љ–Є –Љ–Њ–љ—В–∞–ґ–љ—Л–Љ–Є —Н–ї–µ–Љ–µ–љ—В–∞–Љ–Є. –Ґ–∞–Ї–∞—П –≥–µ–Њ–Љ–µ—В—А–Є—П –љ—Г–ґ–љ–∞ –і–ї—П —В–Њ–≥–Њ, —З—В–Њ–±—Л –Ї—А–µ–њ–µ–ґ –љ–µ –њ—А–Њ–≤–Њ—А–∞—З–Є–≤–∞–ї—Б—П –њ—А–Є —Б–±–Њ—А–Ї–µ –ї–Њ—В–Ї–Њ–≤, –њ–Њ–і–≤–µ—Б–Њ–≤ –Є –і—А—Г–≥–Є—Е –Љ–µ—В–∞–ї–ї–Є—З–µ—Б–Ї–Є—Е —Г–Ј–ї–Њ–≤. –Ш–Ј–і–µ–ї–Є–µ –њ—А–Є–Љ–µ–љ—П–µ—В—Б—П –≤ —Б–±–Њ—А–Ї–µ –Љ–µ—В–∞–ї–ї–Є—З–µ—Б–Ї–Є—Е –Ї–∞–±–µ–ї—М–љ—Л—Е —В—А–∞—Б—Б, —Б—В–Њ–µ–Ї, —Б–Њ–µ–і–Є–љ–Є—В–µ–ї—М–љ—Л—Е –њ–ї–∞—Б—В–Є–љ –Є –Ї—А–µ–њ–µ–ґ–љ—Л—Е –∞–Ї—Б–µ—Б—Б—Г–∞—А–Њ–≤ —Б–µ—А–Є–Є Combitech –Є —Б–Љ–µ–ґ–љ—Л—Е —Б–Є—Б—В–µ–Љ. –Ф–ї—П –њ—А–Њ–Љ—Л—И–ї–µ–љ–љ–Њ–≥–Њ –Љ–Њ–љ—В–∞–ґ–∞ —Н—В–Њ –≤–∞–ґ–љ–∞—П –Љ–µ–ї–Ї–∞—П –њ–Њ–Ј–Є—Ж–Є—П, –њ–Њ—В–Њ–Љ—Г —З—В–Њ –Њ—В —Б—В–∞–љ–і–∞—А—В–Є–Ј–Њ–≤–∞–љ–љ–Њ–≥–Њ –Ї—А–µ–њ–µ–ґ–∞ –Ј–∞–≤–Є—Б–Є—В —Б–Ї–Њ—А–Њ—Б—В—М —Б–±–Њ—А–Ї–Є –Є –њ–Њ–≤—В–Њ—А—П–µ–Љ–Њ—Б—В—М —Г–Ј–ї–Њ–≤. –Ю–±—Л—З–љ–Њ —В–∞–Ї–Є–µ –±–Њ–ї—В—Л –Є–Ј–≥–Њ—В–∞–≤–ї–Є–≤–∞—О—В—Б—П –Є–Ј —Б—В–∞–ї–Є —Б –∞–љ—В–Є–Ї–Њ—А—А–Њ–Ј–Є–Њ–љ–љ—Л–Љ –њ–Њ–Ї—А—Л—В–Є–µ–Љ, –њ–Њ—Н—В–Њ–Љ—Г –Њ–љ–Є –њ–Њ–і—Е–Њ–і—П—В –і–ї—П –≤–љ—Г—В—А–µ–љ–љ–Є—Е —В–µ—Е–љ–Є—З–µ—Б–Ї–Є—Е –њ–Њ–Љ–µ—Й–µ–љ–Є–є –Є —Б—В–∞–љ–і–∞—А—В–љ—Л—Е –њ—А–Њ–Љ—Л—И–ї–µ–љ–љ—Л—Е —Г—Б–ї–Њ–≤–Є–є. –Я—А–Є –њ–Њ–і–±–Њ—А–µ –Њ–±—П–Ј–∞—В–µ–ї—М–љ–Њ –љ—Г–ґ–љ–Њ –њ—А–Њ–≤–µ—А—П—В—М –љ–µ —В–Њ–ї—М–Ї–Њ —А–µ–Ј—М–±—Г M6, –љ–Њ –Є –і–ї–Є–љ—Г 10 –Љ–Љ, –њ–Њ—В–Њ–Љ—Г —З—В–Њ –≤ –Њ–і–љ–Њ–є –Є —В–Њ–є –ґ–µ —Б–Є—Б—В–µ–Љ–µ –Љ–Њ–≥—Г—В –Є—Б–њ–Њ–ї—М–Ј–Њ–≤–∞—В—М—Б—П –њ–Њ—Е–Њ–ґ–Є–µ –±–Њ–ї—В—Л –і—А—Г–≥–Њ–є –і–ї–Є–љ—Л. –Ф–ї—П –Ї–∞—В–∞–ї–Њ–≥–∞ –ї—Г—З—И–µ —Г–Ї–∞–Ј—Л–≤–∞—В—М —В–Њ–≤–∞—А –Ї–∞–Ї —Б–Є—Б—В–µ–Љ–љ—Л–є –Ї—А–µ–њ–µ–ґ DKC, –∞ –љ–µ –Ї–∞–Ї —Г–љ–Є–≤–µ—А—Б–∞–ї—М–љ—Л–є –Љ–µ—В–Є–Ј, —З—В–Њ–±—Л –њ–Њ–Ї—Г–њ–∞—В–µ–ї—М –њ–Њ–љ–Є–Љ–∞–ї –µ–≥–Њ –љ–∞–Ј–љ–∞—З–µ–љ–Є–µ –Є —Б–Њ–≤–Љ–µ—Б—В–Є–Љ–Њ—Б—В—М. –Х—Б–ї–Є –Є–Ј–і–µ–ї–Є–µ –Ј–∞–Ї—Г–њ–∞–µ—В—Б—П –і–ї—П —Б–µ—А–≤–Є—Б–љ—Л—Е –Ї–Њ–Љ–њ–ї–µ–Ї—В–Њ–≤, –њ–Њ–ї–µ–Ј–љ–Њ –і–Њ–њ–Њ–ї–љ–Є—В–µ–ї—М–љ–Њ —Г–Ї–∞–Ј—Л–≤–∞—В—М —Б–Њ–≤–Љ–µ—Б—В–Є–Љ—Г—О –≥–∞–є–Ї—Г –Є —Б–µ—А–Є—О –Љ–Њ–љ—В–∞–ґ–љ—Л—Е –∞–Ї—Б–µ—Б—Б—Г–∞—А–Њ–≤. –Э–∞ –њ—А–∞–Ї—В–Є–Ї–µ —Н—В–∞ –њ–Њ–Ј–Є—Ж–Є—П —З–∞—Й–µ –≤—Б–µ–≥–Њ –њ–Њ–Ї—Г–њ–∞–µ—В—Б—П –љ–µ –њ–Њ—И—В—Г—З–љ–Њ, –∞ –Ї–∞–Ї —А–∞—Б—Е–Њ–і–љ—Л–є –Ї—А–µ–њ–µ–ґ –і–ї—П —Б–±–Њ—А–Ї–Є –Ї–∞–±–µ–ї—М–љ—Л—Е —В—А–∞—Б—Б –Є –Љ–µ—В–∞–ї–ї–Њ–Ї–Њ–љ—Б—В—А—Г–Ї—Ж–Є–є.",
