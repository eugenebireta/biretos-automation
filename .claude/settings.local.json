{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(*git ls-files*)",
      "Bash(*git log*)",
      "Bash(*git show*)",
      "Bash(*git status*)",
      "Bash(*git diff*)",
"Bash(*git merge-base*)",
      "Bash(*git branch*)",
      "Bash(*git add*)",
      "Bash(*git commit*)",
      "Bash(*git checkout*)",
      "Bash(*git pull*)",
      "Bash(*git fetch*)",
      "Bash(*git config*)",
      "Bash(*grep *)",
      "Bash(*cat *)",
      "Bash(*find *)",
      "Bash(*dir *)",
      "Bash(*cd *)",
      "Bash(*ls *)",
      "Bash(*echo *)",
      "Bash(*sort*)",
      "Bash(*head *)",
      "Bash(*python *)",
      "Bash(*pytest *)",
      "Bash(gh --version*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Bash(*git push*)",
      "Bash(*git reset --hard*)",
      "Bash(*git clean -f*)",
      "Bash(*rm -rf*)",
      "Bash(*del /f*)"
    ]
  }
}