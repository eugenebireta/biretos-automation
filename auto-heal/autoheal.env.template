##############################################
# Auto-Heal Environment Configuration
# Скопируйте в autoheal.env и заполните значения
##############################################

# --- OpenRouter API ---
# Используйте существующий ключ (хранится в .env.n8n / deploy.env)
OPENROUTER_API_KEY=
OPENROUTER_REFERER=https://biretos.ae

# --- AI Models ---
# Основная модель генерации патчей
AUTOHEAL_MAIN_MODEL=openai/gpt-5-codex
# Быстрый аналитический движок
AUTOHEAL_ANALYTICS_MODEL=openai/gpt-5-mini
# Fallback для инспекции патчей
AUTOHEAL_FALLBACK_MODEL=anthropic/claude-4.5-sonnet

# --- n8n API ---
# URL и ключ берутся из .env.n8n
N8N_URL=
N8N_API_KEY=

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=biretos_automation
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# --- Telegram Bot ---
# Используйте существующего бота Health Monitor / категорий / экспорта
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Auto-Heal Settings ---
AUTOHEAL_CHECK_INTERVAL=3600          # Интервал мониторинга (секунды)
AUTOHEAL_AUTO_APPLY_LOW_RISK=false    # Запрет авто-применения даже для low risk
AUTOHEAL_MAX_RETRIES=3
AUTOHEAL_BACKUP_RETENTION_DAYS=30
AUTOHEAL_PATCH_RETENTION_DAYS=90
AUTOHEAL_GENERATOR_ENDPOINT=http://127.0.0.1:8787
AUTOHEAL_PATCH_ROOT=/opt/biretos/auto-heal/patches
AUTOHEAL_MAX_ERRORS_24H=5
AUTOHEAL_MAX_STUCK_PRODUCTS=5
AUTOHEAL_MAX_IMAGE_ERRORS=3

# --- Server SSH (для применения патчей) ---
SERVER_IP=216.9.227.124
SSH_USER=root
SSH_KEY_PATH=~/.ssh/id_rsa

# --- Путь до рабочих каталогов (на сервере) ---
REMOTE_AUTOHEAL_BASE=/opt/biretos/auto-heal
REMOTE_MARKETPLACE_BASE=/opt/biretos/marketplace-export
REMOTE_HEALTH_MONITOR_BASE=/opt/biretos/health-monitor

# --- Прочие сервисы ---
IMAGE_PROCESSOR_URL=https://images.biretos.ae
HEALTH_MONITOR_WORKFLOW_ID=
MARKETPLACE_WORKFLOW_ID=
MARKETPLACE_TEST_WORKFLOW_ID=

# --- Логи и отчёты ---
AUTOHEAL_LOG_LEVEL=info
AUTOHEAL_REPORT_CHAT_ID=
AUTOHEAL_SENTRY_DSN=

