{
  "_description": "Script registry — Claude MUST check this before doing any enrichment/catalog work manually",
  "_updated": "2026-04-09",
  "import_pipeline": {
    "order": [
      "catalog_import"
    ],
    "scripts": {
      "catalog_import": {
        "file": "catalog_import.py",
        "purpose": "R1.1 Import Pipeline: Excel/CSV → stg_catalog_imports records",
        "triggers": ["импорт каталога", "import catalog", "import Excel", "загрузи Excel", "stg_catalog"],
        "usage": "python scripts/catalog_import.py --input path/to/file.xlsx --dry-run",
        "inputs": ["Excel (.xlsx) or CSV", "downloads/evidence/evidence_*.json (for enrichment)"],
        "outputs": ["downloads/staging/stg_catalog_imports.json", "downloads/staging/import_report.json"],
        "critical_rule": "PN and brand normalized to UPPER before dedup. Confidence gate routes to accepted/review_required/rejected."
      }
    }
  },
  "enrichment_pipeline": {
    "order": [
      "dr_prompt_generator",
      "(user runs Gemini DR)",
      "dr_results_import",
      "merge_research_to_evidence",
      "download_documents",
      "export_pipeline"
    ],
    "scripts": {
      "dr_prompt_generator": {
        "file": "dr_prompt_generator.py",
        "purpose": "Generate Gemini Deep Research prompts from evidence data",
        "triggers": ["промты для DR", "generate prompts", "какие SKU без данных", "uncovered SKUs"],
        "usage": "python scripts/dr_prompt_generator.py --version v7 --dry-run",
        "inputs": ["downloads/evidence/evidence_*.json"],
        "outputs": ["research_queue/dr_prompts/{version}/"],
        "evidence_fields_used": [
          "assembled_title (hint derivation)",
          "content.seed_name (Excel description — passed to DR)",
          "our_price_raw (reference price RUB — passed to DR)",
          "brand"
        ],
        "evidence_fields_NOT_used": [
          "expected_category (UNRELIABLE — known wrong for many items)"
        ],
        "critical_rule": "Hints from assembled_title + seed_name from Excel. Reference price from our_price_raw. NEVER expected_category."
      },
      "dr_results_import": {
        "file": "dr_results_import.py",
        "purpose": "Import Gemini DR markdown results into structured JSON",
        "triggers": ["импортируй результаты", "import results", "parse DR output"],
        "usage": "python scripts/dr_results_import.py --source-dir C:/Users/eugene/Downloads",
        "inputs": ["*.md files from Gemini DR"],
        "outputs": ["research_results/result_*.json", "training_data/dr_url_training_*.jsonl"],
        "critical_rule": "Handles v1 (Russian), v2 (English), v3 (English+) prompt formats automatically"
      },
      "merge_research_to_evidence": {
        "file": "merge_research_to_evidence.py",
        "purpose": "Merge DR results into evidence bundles",
        "triggers": ["обнови evidence", "merge results", "сколько обогащено", "enrichment stats"],
        "usage": "python scripts/merge_research_to_evidence.py --dry-run",
        "inputs": ["research_results/result_*.json"],
        "outputs": ["downloads/evidence/evidence_*.json"],
        "critical_rule": "Propagates description_ru → content.description_long_ru"
      },
      "download_documents": {
        "file": "download_documents.py",
        "purpose": "Download PDFs, datasheets, and images referenced in evidence",
        "triggers": ["скачай документы", "download docs", "get datasheets"],
        "usage": "python scripts/download_documents.py --dry-run",
        "inputs": ["downloads/evidence/evidence_*.json"],
        "outputs": ["downloads/documents/{PN}/"]
      },
      "export_pipeline": {
        "file": "export_pipeline.py",
        "purpose": "Export enriched catalog to CSV/Excel for InSales import",
        "triggers": ["выгрузи в Excel", "export CSV", "InSales export", "каталог"],
        "usage": "python scripts/export_pipeline.py",
        "inputs": ["downloads/evidence/evidence_*.json"],
        "outputs": ["downloads/catalog_*.xlsx"]
      }
    }
  },
  "other_key_scripts": {
    "photo_pipeline": {
      "file": "photo_pipeline.py",
      "purpose": "Photo search, download, and quality validation"
    },
    "gemini_price_scout": {
      "file": "gemini_price_scout.py",
      "purpose": "Price lookup via Gemini API"
    },
    "research_runner": {
      "file": "research_runner.py",
      "purpose": "Automated research execution with multiple providers"
    },
    "category_resolver": {
      "file": "category_resolver.py",
      "purpose": "Map products to InSales category tree"
    },
    "card_status": {
      "file": "card_status.py",
      "purpose": "Calculate readiness status for each product card"
    },
    "identity_checker": {
      "file": "identity_checker.py",
      "purpose": "Verify product identity against evidence"
    }
  }
}
